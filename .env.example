# Postgres (used by api and docker-compose)
DATABASE_URL=postgresql://wayline:wayline@localhost:5433/wayline

# Redis (used by api for caching milestone scans + LLM outputs)
REDIS_URL=redis://localhost:6380/0

# LLM providers (at least one required; api picks based on which is set)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# api service
API_HOST=0.0.0.0
API_PORT=8000

# web service — URL the Next.js frontend hits for the api
NEXT_PUBLIC_API_URL=http://localhost:8000
